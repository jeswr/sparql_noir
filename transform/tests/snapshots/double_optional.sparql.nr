// Generated by sparql_noir transform
use dep::consts;
use dep::utils;
use dep::types::Triple;

pub(crate) type BGP = [Triple; 3];
pub(crate) struct Variables {
  pub(crate) s: Field,
  pub(crate) a: Field,
  pub(crate) b: Field,
}

pub(crate) fn checkBinding(bgp: BGP, variables: Variables) {
  assert(variables.s == bgp[0].terms[0].hash);
  assert(bgp[0].terms[2].hash == bgp[0].terms[2].hash);
  assert(variables.s == bgp[1].terms[0].hash);
  assert(variables.a == bgp[1].terms[2].hash);
  assert(variables.s == bgp[1].terms[0].hash);
  assert(variables.b == bgp[1].terms[2].hash);
  assert(consts::hash2([0, consts::encode_string("http://example.org/p")]) == bgp[0].terms[1].hash);
  assert(consts::hash2([0, consts::encode_string("http://example.org/a")]) == bgp[1].terms[1].hash);
  assert(consts::hash2([0, consts::encode_string("http://example.org/b")]) == bgp[1].terms[1].hash);
}
